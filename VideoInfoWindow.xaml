<Window x:Class="FramePlayer.VideoInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Video Info"
        Width="720"
        Height="640"
        MinWidth="620"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="#17191D"
        Foreground="#F3F4F6"
        ShowInTaskbar="False">
  <Window.Resources>
    <SolidColorBrush x:Key="PanelBrush" Color="#21252B" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#31363F" />
    <SolidColorBrush x:Key="MutedBrush" Color="#B7BDC6" />
    <SolidColorBrush x:Key="ValueBrush" Color="#F3F4F6" />

    <Style x:Key="CardBorderStyle" TargetType="Border">
      <Setter Property="Margin" Value="0,0,0,12" />
      <Setter Property="Padding" Value="16" />
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style x:Key="CardTitleTextStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style x:Key="PropertyLabelTextStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Margin" Value="0,2,12,0" />
      <Setter Property="VerticalAlignment" Value="Top" />
    </Style>

    <Style x:Key="SelectableValueTextBoxStyle" TargetType="TextBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{StaticResource ValueBrush}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="IsReadOnly" Value="True" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="AcceptsReturn" Value="True" />
      <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
      <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
      <Setter Property="Focusable" Value="True" />
      <Setter Property="IsTabStop" Value="False" />
      <Setter Property="CaretBrush" Value="{StaticResource ValueBrush}" />
    </Style>

    <Style TargetType="Button">
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Background" Value="#2A2F37" />
      <Setter Property="Foreground" Value="#F3F4F6" />
      <Setter Property="BorderBrush" Value="#3B424D" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <DataTemplate x:Key="InspectorFieldTemplate">
      <Grid Margin="0,0,0,10">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="164" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0"
                   Style="{StaticResource PropertyLabelTextStyle}"
                   Text="{Binding Label}" />
        <TextBox Grid.Column="1"
                 Style="{StaticResource SelectableValueTextBoxStyle}"
                 Text="{Binding Value, Mode=OneWay}"
                 ToolTip="{Binding Value}" />
      </Grid>
    </DataTemplate>
  </Window.Resources>

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel>
      <TextBlock x:Name="PaneTextBlock"
                 FontSize="12"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource MutedBrush}"
                 Text="Primary pane" />
      <TextBlock x:Name="HeadingTextBlock"
                 Margin="0,6,0,0"
                 FontSize="24"
                 FontWeight="SemiBold"
                 Text="Video Info"
                 TextWrapping="Wrap" />
      <TextBox x:Name="PathTextBox"
               Margin="0,10,0,0"
               Style="{StaticResource SelectableValueTextBoxStyle}"
               Foreground="{StaticResource MutedBrush}"
               FontSize="12"
               Text="Path" />
    </StackPanel>

    <ScrollViewer Grid.Row="1"
                  Margin="0,16,0,0"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <Border Style="{StaticResource CardBorderStyle}">
          <StackPanel>
            <TextBlock Text="Summary"
                       Style="{StaticResource CardTitleTextStyle}" />
            <ItemsControl x:Name="SummaryItemsControl"
                          ItemTemplate="{StaticResource InspectorFieldTemplate}" />
          </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}">
          <StackPanel>
            <TextBlock Text="Video"
                       Style="{StaticResource CardTitleTextStyle}" />
            <ItemsControl x:Name="VideoItemsControl"
                          ItemTemplate="{StaticResource InspectorFieldTemplate}" />
          </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}">
          <StackPanel>
            <TextBlock Text="Audio"
                       Style="{StaticResource CardTitleTextStyle}" />
            <TextBlock x:Name="AudioEmptyTextBlock"
                       Visibility="Collapsed"
                       Foreground="{StaticResource MutedBrush}"
                       FontSize="13"
                       Text="No audio stream detected." />
            <ItemsControl x:Name="AudioItemsControl"
                          ItemTemplate="{StaticResource InspectorFieldTemplate}" />
          </StackPanel>
        </Border>

        <Expander x:Name="AdvancedExpander"
                  Margin="0,0,0,12"
                  IsExpanded="False">
          <Expander.Header>
            <TextBlock Text="Advanced"
                       FontSize="15"
                       FontWeight="SemiBold" />
          </Expander.Header>
          <Border Margin="0,10,0,0"
                  Style="{StaticResource CardBorderStyle}">
            <ItemsControl x:Name="AdvancedItemsControl"
                          ItemTemplate="{StaticResource InspectorFieldTemplate}" />
          </Border>
        </Expander>
      </StackPanel>
    </ScrollViewer>

    <StackPanel Grid.Row="2"
                Margin="0,12,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
      <Button Width="88"
              IsDefault="True"
              IsCancel="True"
              Content="Close"
              Click="CloseButton_Click" />
    </StackPanel>
  </Grid>
</Window>
