<Window x:Class="FramePlayer.VideoInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Video Info"
        Width="620"
        Height="520"
        MinWidth="520"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="#17191D"
        Foreground="#F3F4F6"
        ShowInTaskbar="False">
  <Window.Resources>
    <SolidColorBrush x:Key="PanelBrush" Color="#21252B" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#31363F" />
    <SolidColorBrush x:Key="MutedBrush" Color="#B7BDC6" />

    <Style TargetType="Button">
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Background" Value="#2A2F37" />
      <Setter Property="Foreground" Value="#F3F4F6" />
      <Setter Property="BorderBrush" Value="#3B424D" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="12" />
    </Style>
  </Window.Resources>

  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel>
      <TextBlock x:Name="HeadingTextBlock"
                 FontSize="24"
                 FontWeight="SemiBold"
                 Text="Video Info" />
      <TextBlock x:Name="SubheadingTextBlock"
                 Margin="0,8,0,0"
                 Foreground="{StaticResource MutedBrush}"
                 FontSize="13"
                 LineHeight="20"
                 TextWrapping="Wrap"
                 Text="Focused pane media details" />
    </StackPanel>

    <Border Grid.Row="1"
            Margin="0,14,0,0"
            Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="14">
      <TextBox x:Name="DetailsTextBox"
               Background="#17191D"
               BorderThickness="0"
               Foreground="#F3F4F6"
               FontFamily="Consolas"
               FontSize="12"
               IsReadOnly="True"
               IsReadOnlyCaretVisible="False"
               TextWrapping="Wrap"
               AcceptsReturn="True"
               VerticalScrollBarVisibility="Auto"
               HorizontalScrollBarVisibility="Disabled" />
    </Border>

    <StackPanel Grid.Row="2"
                Margin="0,12,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
      <Button Width="88"
              IsDefault="True"
              IsCancel="True"
              Content="Close"
              Click="CloseButton_Click" />
    </StackPanel>
  </Grid>
</Window>
