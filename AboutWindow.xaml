<Window x:Class="FramePlayer.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Frame Player"
        Width="460"
        Height="380"
        MinWidth="440"
        MinHeight="340"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterOwner"
        Background="#17191D"
        Foreground="#F3F4F6"
        ShowInTaskbar="False">
  <Window.Resources>
    <SolidColorBrush x:Key="PanelBrush" Color="#21252B" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#31363F" />
    <SolidColorBrush x:Key="MutedBrush" Color="#B7BDC6" />

    <Style TargetType="Button">
      <Setter Property="Margin" Value="0,0,0,0" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Background" Value="#2A2F37" />
      <Setter Property="Foreground" Value="#F3F4F6" />
      <Setter Property="BorderBrush" Value="#3B424D" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="12" />
    </Style>
  </Window.Resources>

  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="18">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <TextBlock FontSize="24"
                     FontWeight="SemiBold"
                     Text="Frame Player" />
          <TextBlock x:Name="VersionTextBlock"
                     Margin="0,4,0,0"
                     Foreground="{StaticResource MutedBrush}"
                     FontFamily="Consolas"
                     FontSize="12"
                     Text="Version --" />

          <TextBlock Margin="0,16,0,0"
                     FontSize="16"
                     FontWeight="SemiBold"
                     TextWrapping="Wrap"
                     Text="Designed by jfleezy23 and built by CODEX." />

          <TextBlock Margin="0,12,0,0"
                     Foreground="{StaticResource MutedBrush}"
                     FontSize="13"
                     LineHeight="20"
                     TextWrapping="Wrap">
            Frame Player was designed by Jonathan Floyd and published under the jfleezy23 Git identity, with implementation support from CODEX.
          </TextBlock>

          <Border Margin="0,16,0,0"
                  Background="#1C2026"
                  BorderBrush="{StaticResource PanelBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="10"
                  Padding="12">
            <StackPanel>
              <TextBlock Foreground="{StaticResource MutedBrush}"
                         FontSize="11"
                         Text="Credits" />
              <TextBlock Margin="0,6,0,0"
                         FontSize="13"
                         Text="Jonathan Floyd" />
              <TextBlock Foreground="{StaticResource MutedBrush}"
                         FontFamily="Consolas"
                         FontSize="12"
                         Text="Git: jfleezy23" />
              <TextBlock Margin="0,10,0,0"
                         FontSize="13"
                         Text="CODEX" />
              <TextBlock Foreground="{StaticResource MutedBrush}"
                         FontSize="12"
                         Text="App development and implementation support" />
            </StackPanel>
          </Border>

          <TextBlock Margin="0,16,0,0"
                     Foreground="{StaticResource MutedBrush}"
                     FontSize="12"
                     TextWrapping="Wrap"
                     Text="WPF desktop UI, FFME playback, bundled FFmpeg runtime. License and third-party notices ship with the package instead of the About window." />
        </StackPanel>
      </ScrollViewer>
    </Border>

    <StackPanel Grid.Row="1"
                Margin="0,12,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
      <Button Width="88"
              IsDefault="True"
              IsCancel="True"
              Content="Close"
              Click="CloseButton_Click" />
    </StackPanel>
  </Grid>
</Window>
