<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FramePlayer.Desktop.Views.MainWindow"
        Title="Frame Player"
        Width="1280"
        Height="820"
        MinWidth="1040"
        MinHeight="720"
        WindowDecorations="Full"
        Background="#11161C"
        Foreground="#F3F4F6"
        FontFamily="Inter, Segoe UI">
  <Window.Styles>
    <Style Selector="Button">
      <Setter Property="Margin" Value="0,0,6,0" />
      <Setter Property="Padding" Value="11,7" />
      <Setter Property="Background" Value="#2A2F37" />
      <Setter Property="Foreground" Value="#F3F4F6" />
      <Setter Property="BorderBrush" Value="#3B424D" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="Button:pointerover">
      <Setter Property="Background" Value="#343B45" />
      <Setter Property="BorderBrush" Value="#5AA9E6" />
    </Style>
    <Style Selector="Button.transport-button">
      <Setter Property="Width" Value="38" />
      <Setter Property="MinWidth" Value="38" />
      <Setter Property="MaxWidth" Value="38" />
      <Setter Property="Height" Value="34" />
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="MaxHeight" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="CornerRadius" Value="7" />
    </Style>
    <Style Selector="Button.pane-transport-button">
      <Setter Property="Width" Value="38" />
    </Style>
    <Style Selector="Viewbox.transport-icon">
      <Setter Property="Width" Value="18" />
      <Setter Property="Height" Value="18" />
      <Setter Property="Stretch" Value="Uniform" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.loop-status">
      <Setter Property="Width" Value="240" />
      <Setter Property="Height" Value="16" />
      <Setter Property="Foreground" Value="#B7BDC6" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="TextAlignment" Value="Right" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
      <Setter Property="TextWrapping" Value="NoWrap" />
      <Setter Property="HorizontalAlignment" Value="Right" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.main-loop-status">
      <Setter Property="Height" Value="20" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="TextBlock.pane-loop-status">
      <Setter Property="Width" Value="176" />
    </Style>
    <Style Selector="StackPanel.frame-entry">
      <Setter Property="Orientation" Value="Horizontal" />
      <Setter Property="HorizontalAlignment" Value="Right" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="StackPanel.pane-frame-entry">
      <Setter Property="Margin" Value="0,6,0,0" />
    </Style>
    <Style Selector="TextBlock.frame-entry-label">
      <Setter Property="Foreground" Value="#B7BDC6" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Margin" Value="0,0,6,0" />
    </Style>
    <Style Selector="TextBox.frame-number-box">
      <Setter Property="Width" Value="104" />
      <Setter Property="Height" Value="32" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="MaxHeight" Value="32" />
      <Setter Property="Padding" Value="8,3" />
      <Setter Property="HorizontalContentAlignment" Value="Right" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBox.pane-frame-number-box">
      <Setter Property="Width" Value="92" />
    </Style>
    <Style Selector="TextBlock.status-text">
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
      <Setter Property="TextWrapping" Value="NoWrap" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Slider.timeline-slider">
      <Setter Property="Height" Value="34" />
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="ClipToBounds" Value="False" />
    </Style>
    <Style Selector="Slider.timeline-slider /template/ Track#PART_Track">
      <Setter Property="Margin" Value="12,0" />
      <Setter Property="ClipToBounds" Value="False" />
    </Style>
    <Style Selector="Slider.timeline-slider /template/ Thumb">
      <Setter Property="Width" Value="10" />
      <Setter Property="Height" Value="18" />
      <Setter Property="Background" Value="#F3F4F6" />
      <Setter Property="BorderBrush" Value="#F3F4F6" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="ClipToBounds" Value="False" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="Background" Value="#171C22" />
      <Setter Property="Foreground" Value="#F3F4F6" />
      <Setter Property="BorderBrush" Value="#3B424D" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="8,5" />
    </Style>
  </Window.Styles>

  <Border BorderBrush="#31363F" BorderThickness="1" Background="#11161C">
    <Grid RowDefinitions="Auto,Auto,*,134,38">
      <Border Grid.Row="0" x:Name="HeaderPanel" Margin="10,10,10,0" Background="#21252B" BorderBrush="#31363F" BorderThickness="1" CornerRadius="10" Padding="10">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel>
            <TextBlock Text="Current Video" Foreground="#B7BDC6" FontSize="11" />
            <TextBlock x:Name="CurrentFileTextBlock" Margin="0,3,0,0" Text="No file loaded" Foreground="#F3F4F6" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
          </StackPanel>
          <CheckBox x:Name="CompareModeCheckBox" Grid.Column="1" Content="Two-Pane Compare" Margin="12,0,0,0" VerticalAlignment="Center" IsCheckedChanged="CompareModeCheckBox_IsCheckedChanged" />
        </Grid>
      </Border>

      <Border Grid.Row="1" x:Name="CompareToolbarBorder" Background="#1A2028" BorderBrush="#28313B" BorderThickness="0,0,0,1" Padding="18,8" IsVisible="False">
        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*" ColumnSpacing="8">
          <CheckBox x:Name="AllPanesCheckBox" Content="All panes" IsChecked="True" />
          <Button x:Name="AlignRightToLeftButton" Grid.Column="1" Content="Sync Right to Left" ToolTip.Tip="Frame first: syncs the right pane to the left pane with exact frame identity when available." Click="AlignRightToLeftButton_Click" />
          <Button x:Name="AlignLeftToRightButton" Grid.Column="2" Content="Sync Left to Right" ToolTip.Tip="Frame first: syncs the left pane to the right pane with exact frame identity when available." Click="AlignLeftToRightButton_Click" />
          <CheckBox x:Name="LinkPaneZoomCheckBox" Grid.Column="3" Content="Link zoom" IsChecked="True" />
          <TextBlock x:Name="CompareStatusTextBlock" Grid.Column="4" Text="Compare: Load two videos to begin | Last sync: none" Foreground="#B7BDC6" VerticalAlignment="Center" Margin="12,0,0,0" MinWidth="0" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
        </Grid>
      </Border>

      <Border Grid.Row="2" x:Name="VideoPanel" Background="#11161C" Padding="14">
        <Grid ColumnDefinitions="*,0" x:Name="VideoPaneGrid" ColumnSpacing="12">
          <Border x:Name="PrimaryPaneBorder" Grid.Column="0" Background="#171C22" BorderBrush="#28313B" BorderThickness="1" CornerRadius="8" Tag="pane-primary" PointerPressed="PaneBorder_PointerPressed">
            <Grid RowDefinitions="42,*,118">
              <Border x:Name="PrimaryPaneHeaderBorder" Grid.Row="0" Background="#1D2934" BorderBrush="#28313B" BorderThickness="0,0,0,1" CornerRadius="8,8,0,0" Padding="12,7">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel>
                    <TextBlock x:Name="PrimaryPaneTitleTextBlock" Text="Primary" FontWeight="SemiBold" />
                    <TextBlock x:Name="PrimaryPaneFileTextBlock" Text="No video loaded" Foreground="#B7BDC6" FontSize="11" TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                  <TextBlock x:Name="PrimaryPaneStateTextBlock" Grid.Column="1" Text="Ready" Foreground="#B7BDC6" VerticalAlignment="Center" />
                </Grid>
              </Border>
              <Border Grid.Row="1" x:Name="CustomVideoSurfaceHost" Background="#050608" ClipToBounds="True" Tag="pane-primary" PointerPressed="PaneBorder_PointerPressed">
                <Grid>
                  <Image x:Name="CustomVideoSurface" Stretch="Uniform" />
                  <StackPanel x:Name="PrimaryEmptyStateOverlay" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="7">
                    <TextBlock x:Name="PrimaryEmptyStateTitleTextBlock" Text="Drop a video to begin" Foreground="#F3F4F6" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock x:Name="PrimaryEmptyStateBodyTextBlock" Text="AVI, M4V, MP4, MKV, and WMV review with exact frame controls" Foreground="#B7BDC6" HorizontalAlignment="Center" />
                    <Button Content="Open Video" HorizontalAlignment="Center" Click="OpenVideoButton_Click" />
                  </StackPanel>
                </Grid>
              </Border>
              <Border x:Name="PrimaryPaneFooterBorder" Grid.Row="2" Background="#171C22" BorderBrush="#28313B" BorderThickness="0,1,0,0" CornerRadius="0,0,8,8" Padding="10" IsVisible="False">
                <Grid RowDefinitions="Auto,16,Auto" ColumnDefinitions="Auto,*,176">
                  <TextBlock x:Name="PrimaryPaneCurrentPositionTextBlock" Text="00:00:00.000" Foreground="#B7BDC6" VerticalAlignment="Center" />
                  <Slider x:Name="PrimaryPanePositionSlider" Grid.Column="1" Classes="timeline-slider" Margin="10,0" Minimum="0" Maximum="1" Tag="pane-primary" PointerPressed="TimelineSlider_PointerPressed" ValueChanged="PanePositionSlider_ValueChanged" />
                  <TextBlock x:Name="PrimaryPaneDurationTextBlock" Grid.Column="2" Text="00:00:00.000" Foreground="#B7BDC6" HorizontalAlignment="Right" TextAlignment="Right" VerticalAlignment="Center" />
                  <TextBlock x:Name="PrimaryPaneLoopStatusTextBlock" Grid.Row="1" Grid.Column="2" Classes="loop-status pane-loop-status" Text="Loop: off" />
                  <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                    <Button x:Name="PrimaryPaneStepBackButton" Classes="transport-button pane-transport-button" Tag="pane-primary" Click="PaneStepBackButton_Click" ToolTip.Tip="Previous Frame">
                      <Viewbox Classes="transport-icon">
                        <Canvas Width="20" Height="20">
                          <Path Fill="#F3F4F6" Data="M 3,3 L 5,3 L 5,17 L 3,17 Z" />
                          <Path Fill="#F3F4F6" Data="M 18,3 L 7,10 L 18,17 Z" />
                        </Canvas>
                      </Viewbox>
                    </Button>
                    <Button x:Name="PrimaryPaneSkipBackHundredFramesButton" Classes="transport-button pane-transport-button" Tag="pane-primary" Click="PaneSkipBackHundredFramesButton_Click" ToolTip.Tip="Rewind 100 Frames">
                      <Viewbox Classes="transport-icon">
                        <Canvas Width="20" Height="20">
                          <Path Fill="#F3F4F6" Data="M 10,3 L 2,10 L 10,17 Z" />
                          <Path Fill="#F3F4F6" Data="M 19,3 L 11,10 L 19,17 Z" />
                        </Canvas>
                      </Viewbox>
                    </Button>
                    <Button x:Name="PrimaryPanePlayPauseButton" Classes="transport-button pane-transport-button" Tag="pane-primary" Click="PanePlayPauseButton_Click" ToolTip.Tip="Play">
                      <Grid Width="18" Height="18">
                        <Viewbox x:Name="PrimaryPanePlayPausePlayIcon" Classes="transport-icon">
                          <Canvas Width="20" Height="20">
                            <Path Fill="#F3F4F6" Data="M 5,3 L 18,10 L 5,17 Z" />
                          </Canvas>
                        </Viewbox>
                        <Viewbox x:Name="PrimaryPanePlayPausePauseIcon" Classes="transport-icon" IsVisible="False">
                          <Canvas Width="20" Height="20">
                            <Path Fill="#F3F4F6" Data="M 5,3 L 9,3 L 9,17 L 5,17 Z" />
                            <Path Fill="#F3F4F6" Data="M 12,3 L 16,3 L 16,17 L 12,17 Z" />
                          </Canvas>
                        </Viewbox>
                      </Grid>
                    </Button>
                    <Button x:Name="PrimaryPaneSkipForwardHundredFramesButton" Classes="transport-button pane-transport-button" Tag="pane-primary" Click="PaneSkipForwardHundredFramesButton_Click" ToolTip.Tip="Fast Forward 100 Frames">
                      <Viewbox Classes="transport-icon">
                        <Canvas Width="20" Height="20">
                          <Path Fill="#F3F4F6" Data="M 1,3 L 9,10 L 1,17 Z" />
                          <Path Fill="#F3F4F6" Data="M 10,3 L 18,10 L 10,17 Z" />
                        </Canvas>
                      </Viewbox>
                    </Button>
                    <Button x:Name="PrimaryPaneStepForwardButton" Classes="transport-button pane-transport-button" Tag="pane-primary" Click="PaneStepForwardButton_Click" ToolTip.Tip="Next Frame">
                      <Viewbox Classes="transport-icon">
                        <Canvas Width="20" Height="20">
                          <Path Fill="#F3F4F6" Data="M 15,3 L 17,3 L 17,17 L 15,17 Z" />
                          <Path Fill="#F3F4F6" Data="M 2,3 L 13,10 L 2,17 Z" />
                        </Canvas>
                      </Viewbox>
                    </Button>
                  </StackPanel>
                  <StackPanel Grid.Row="2" Grid.Column="2" Classes="frame-entry pane-frame-entry">
                    <TextBlock Classes="frame-entry-label" Text="Frame" />
                    <TextBox x:Name="PrimaryPaneFrameNumberTextBox" Classes="frame-number-box pane-frame-number-box" Tag="pane-primary" KeyDown="FrameNumberTextBox_KeyDown" />
                  </StackPanel>
                </Grid>
              </Border>
            </Grid>
          </Border>

          <Border x:Name="ComparePaneBorder" Grid.Column="1" Background="#171C22" BorderBrush="#28313B" BorderThickness="1" CornerRadius="8" Tag="pane-compare" PointerPressed="PaneBorder_PointerPressed" IsVisible="False">
            <Grid RowDefinitions="42,*,118">
              <Border x:Name="ComparePaneHeaderBorder" Grid.Row="0" Background="#171C22" BorderBrush="#28313B" BorderThickness="0,0,0,1" CornerRadius="8,8,0,0" Padding="12,7">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel>
                    <TextBlock x:Name="ComparePaneTitleTextBlock" Text="Compare" FontWeight="SemiBold" />
                    <TextBlock x:Name="ComparePaneFileTextBlock" Text="No video loaded" Foreground="#B7BDC6" FontSize="11" TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                  <TextBlock x:Name="ComparePaneStateTextBlock" Grid.Column="1" Text="Ready" Foreground="#B7BDC6" VerticalAlignment="Center" />
                </Grid>
              </Border>
              <Border Grid.Row="1" x:Name="CompareVideoSurfaceHost" Background="#050608" ClipToBounds="True" Tag="pane-compare" PointerPressed="PaneBorder_PointerPressed">
                <Grid>
                  <Image x:Name="CompareVideoSurface" Stretch="Uniform" />
                  <StackPanel x:Name="CompareEmptyStateOverlay" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="7">
                    <TextBlock x:Name="CompareEmptyStateTitleTextBlock" Text="Open compare video" Foreground="#F3F4F6" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock x:Name="CompareEmptyStateBodyTextBlock" Text="Use two-pane compare for original vs processed review" Foreground="#B7BDC6" HorizontalAlignment="Center" />
                    <Button Content="Open Compare Video" HorizontalAlignment="Center" Click="OpenCompareVideoButton_Click" />
                  </StackPanel>
                </Grid>
              </Border>
              <Border x:Name="ComparePaneFooterBorder" Grid.Row="2" Background="#171C22" BorderBrush="#28313B" BorderThickness="0,1,0,0" CornerRadius="0,0,8,8" Padding="10">
                <Grid RowDefinitions="Auto,16,Auto" ColumnDefinitions="Auto,*,176">
                  <TextBlock x:Name="ComparePaneCurrentPositionTextBlock" Text="00:00:00.000" Foreground="#B7BDC6" VerticalAlignment="Center" />
                  <Slider x:Name="ComparePanePositionSlider" Grid.Column="1" Classes="timeline-slider" Margin="10,0" Minimum="0" Maximum="1" Tag="pane-compare" PointerPressed="TimelineSlider_PointerPressed" ValueChanged="PanePositionSlider_ValueChanged" />
                  <TextBlock x:Name="ComparePaneDurationTextBlock" Grid.Column="2" Text="00:00:00.000" Foreground="#B7BDC6" HorizontalAlignment="Right" TextAlignment="Right" VerticalAlignment="Center" />
                  <TextBlock x:Name="ComparePaneLoopStatusTextBlock" Grid.Row="1" Grid.Column="2" Classes="loop-status pane-loop-status" Text="Loop: off" />
                  <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                    <Button x:Name="ComparePaneStepBackButton" Classes="transport-button pane-transport-button" Tag="pane-compare" Click="PaneStepBackButton_Click" ToolTip.Tip="Previous Frame">
                      <Viewbox Classes="transport-icon">
                        <Canvas Width="20" Height="20">
                          <Path Fill="#F3F4F6" Data="M 3,3 L 5,3 L 5,17 L 3,17 Z" />
                          <Path Fill="#F3F4F6" Data="M 18,3 L 7,10 L 18,17 Z" />
                        </Canvas>
                      </Viewbox>
                    </Button>
                    <Button x:Name="ComparePaneSkipBackHundredFramesButton" Classes="transport-button pane-transport-button" Tag="pane-compare" Click="PaneSkipBackHundredFramesButton_Click" ToolTip.Tip="Rewind 100 Frames">
                      <Viewbox Classes="transport-icon">
                        <Canvas Width="20" Height="20">
                          <Path Fill="#F3F4F6" Data="M 10,3 L 2,10 L 10,17 Z" />
                          <Path Fill="#F3F4F6" Data="M 19,3 L 11,10 L 19,17 Z" />
                        </Canvas>
                      </Viewbox>
                    </Button>
                    <Button x:Name="ComparePanePlayPauseButton" Classes="transport-button pane-transport-button" Tag="pane-compare" Click="PanePlayPauseButton_Click" ToolTip.Tip="Play">
                      <Grid Width="18" Height="18">
                        <Viewbox x:Name="ComparePanePlayPausePlayIcon" Classes="transport-icon">
                          <Canvas Width="20" Height="20">
                            <Path Fill="#F3F4F6" Data="M 5,3 L 18,10 L 5,17 Z" />
                          </Canvas>
                        </Viewbox>
                        <Viewbox x:Name="ComparePanePlayPausePauseIcon" Classes="transport-icon" IsVisible="False">
                          <Canvas Width="20" Height="20">
                            <Path Fill="#F3F4F6" Data="M 5,3 L 9,3 L 9,17 L 5,17 Z" />
                            <Path Fill="#F3F4F6" Data="M 12,3 L 16,3 L 16,17 L 12,17 Z" />
                          </Canvas>
                        </Viewbox>
                      </Grid>
                    </Button>
                    <Button x:Name="ComparePaneSkipForwardHundredFramesButton" Classes="transport-button pane-transport-button" Tag="pane-compare" Click="PaneSkipForwardHundredFramesButton_Click" ToolTip.Tip="Fast Forward 100 Frames">
                      <Viewbox Classes="transport-icon">
                        <Canvas Width="20" Height="20">
                          <Path Fill="#F3F4F6" Data="M 1,3 L 9,10 L 1,17 Z" />
                          <Path Fill="#F3F4F6" Data="M 10,3 L 18,10 L 10,17 Z" />
                        </Canvas>
                      </Viewbox>
                    </Button>
                    <Button x:Name="ComparePaneStepForwardButton" Classes="transport-button pane-transport-button" Tag="pane-compare" Click="PaneStepForwardButton_Click" ToolTip.Tip="Next Frame">
                      <Viewbox Classes="transport-icon">
                        <Canvas Width="20" Height="20">
                          <Path Fill="#F3F4F6" Data="M 15,3 L 17,3 L 17,17 L 15,17 Z" />
                          <Path Fill="#F3F4F6" Data="M 2,3 L 13,10 L 2,17 Z" />
                        </Canvas>
                      </Viewbox>
                    </Button>
                  </StackPanel>
                  <StackPanel Grid.Row="2" Grid.Column="2" Classes="frame-entry pane-frame-entry">
                    <TextBlock Classes="frame-entry-label" Text="Frame" />
                    <TextBox x:Name="ComparePaneFrameNumberTextBox" Classes="frame-number-box pane-frame-number-box" Tag="pane-compare" KeyDown="FrameNumberTextBox_KeyDown" />
                  </StackPanel>
                </Grid>
              </Border>
            </Grid>
          </Border>
        </Grid>
      </Border>

      <Border Grid.Row="3" x:Name="ControlPanel" Background="#21252B" BorderBrush="#31363F" BorderThickness="0,1,0,0" Padding="18,14,18,16" MinHeight="134">
        <Grid RowDefinitions="40,20,42" ColumnDefinitions="Auto,*,240">
          <TextBlock x:Name="CurrentPositionTextBlock" Text="00:00:00.000" Foreground="#B7BDC6" VerticalAlignment="Center" />
          <Slider x:Name="PositionSlider" Grid.Column="1" Classes="timeline-slider" Margin="12,0" Minimum="0" Maximum="1" PointerPressed="TimelineSlider_PointerPressed" ValueChanged="PositionSlider_ValueChanged" />
          <TextBlock x:Name="DurationTextBlock" Grid.Column="2" Text="00:00:00.000" Foreground="#B7BDC6" HorizontalAlignment="Right" TextAlignment="Right" VerticalAlignment="Center" />
          <TextBlock x:Name="LoopStatusTextBlock" Grid.Row="1" Grid.Column="2" Classes="loop-status main-loop-status" Text="Loop: off" />
          <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button x:Name="PreviousFrameButton" Classes="transport-button" Click="PreviousFrameButton_Click" ToolTip.Tip="Previous Frame">
              <Viewbox Classes="transport-icon">
                <Canvas Width="20" Height="20">
                  <Path Fill="#F3F4F6" Data="M 3,3 L 5,3 L 5,17 L 3,17 Z" />
                  <Path Fill="#F3F4F6" Data="M 18,3 L 7,10 L 18,17 Z" />
                </Canvas>
              </Viewbox>
            </Button>
            <Button x:Name="RewindButton" Classes="transport-button" Click="RewindButton_Click" ToolTip.Tip="Rewind 5 seconds">
              <Viewbox Classes="transport-icon">
                <Canvas Width="20" Height="20">
                  <Path Fill="#F3F4F6" Data="M 10,3 L 2,10 L 10,17 Z" />
                  <Path Fill="#F3F4F6" Data="M 19,3 L 11,10 L 19,17 Z" />
                </Canvas>
              </Viewbox>
            </Button>
            <Button x:Name="PlayPauseButton" Classes="transport-button" Click="PlayPauseButton_Click">
              <Grid Width="18" Height="18">
                <Viewbox x:Name="PlayPausePlayIcon" Classes="transport-icon">
                  <Canvas Width="20" Height="20">
                    <Path Fill="#F3F4F6" Data="M 5,3 L 18,10 L 5,17 Z" />
                  </Canvas>
                </Viewbox>
                <Viewbox x:Name="PlayPausePauseIcon" Classes="transport-icon" IsVisible="False">
                  <Canvas Width="20" Height="20">
                    <Path Fill="#F3F4F6" Data="M 5,3 L 9,3 L 9,17 L 5,17 Z" />
                    <Path Fill="#F3F4F6" Data="M 12,3 L 16,3 L 16,17 L 12,17 Z" />
                  </Canvas>
                </Viewbox>
              </Grid>
            </Button>
            <Button x:Name="FastForwardButton" Classes="transport-button" Click="FastForwardButton_Click" ToolTip.Tip="Fast Forward 5 seconds">
              <Viewbox Classes="transport-icon">
                <Canvas Width="20" Height="20">
                  <Path Fill="#F3F4F6" Data="M 1,3 L 9,10 L 1,17 Z" />
                  <Path Fill="#F3F4F6" Data="M 10,3 L 18,10 L 10,17 Z" />
                </Canvas>
              </Viewbox>
            </Button>
            <Button x:Name="NextFrameButton" Classes="transport-button" Click="NextFrameButton_Click" ToolTip.Tip="Next Frame">
              <Viewbox Classes="transport-icon">
                <Canvas Width="20" Height="20">
                  <Path Fill="#F3F4F6" Data="M 15,3 L 17,3 L 17,17 L 15,17 Z" />
                  <Path Fill="#F3F4F6" Data="M 2,3 L 13,10 L 2,17 Z" />
                </Canvas>
              </Viewbox>
            </Button>
            <Button x:Name="ToggleFullScreenButton" Classes="transport-button" Click="ToggleFullScreenMenuItem_Click" ToolTip.Tip="Toggle Full Screen">
              <Viewbox Classes="transport-icon">
                <Canvas Width="20" Height="20">
                  <Path Stroke="#F3F4F6" StrokeThickness="2" StrokeLineCap="Square" StrokeJoin="Miter" Data="M 3,7 L 3,3 L 7,3 M 13,3 L 17,3 L 17,7 M 17,13 L 17,17 L 13,17 M 7,17 L 3,17 L 3,13" />
                </Canvas>
              </Viewbox>
            </Button>
          </StackPanel>
          <StackPanel Grid.Row="2" Grid.Column="2" Classes="frame-entry">
            <TextBlock Classes="frame-entry-label" Text="Frame" />
            <TextBox x:Name="FrameNumberTextBox" Classes="frame-number-box" KeyDown="FrameNumberTextBox_KeyDown" />
          </StackPanel>
        </Grid>
      </Border>

      <Border Grid.Row="4" x:Name="StatusPanelContainer" Background="#171C22" BorderBrush="#31363F" BorderThickness="0,1,0,0" Padding="10,0" MinHeight="38">
        <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto">
          <TextBlock x:Name="PlaybackStateTextBlock" Classes="status-text" Text="Ready" Foreground="#B7BDC6" Margin="0,0,22,0" />
          <TextBlock x:Name="CurrentFrameTextBlock" Grid.Column="1" Classes="status-text" Text="Frame --" Foreground="#B7BDC6" Margin="0,0,22,0" />
          <TextBlock x:Name="TimecodeTextBlock" Grid.Column="2" Classes="status-text" Text="Timecode --" Foreground="#B7BDC6" Margin="0,0,22,0" />
          <TextBlock x:Name="CacheStatusTextBlock" Grid.Column="3" Classes="status-text" Text="Cache: idle" Foreground="#B7BDC6" />
          <TextBlock x:Name="PointerCoordinatesTextBlock" Grid.Column="4" Classes="status-text" Text="x -- y --" Foreground="#B7BDC6" />
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>
