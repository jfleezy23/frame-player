<Window x:Class="FramePlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FramePlayer.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Frame Player"
        Width="1280"
        Height="820"
        MinWidth="1040"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="Transparent"
        Foreground="#F3F4F6"
        FontFamily="Segoe UI"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowDrop="True"
        Closed="Window_Closed"
        Drop="Window_Drop"
        PreviewDragOver="Window_PreviewDragOver"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp"
        StateChanged="Window_StateChanged">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="0"
                        CornerRadius="0"
                        GlassFrameThickness="0"
                        ResizeBorderThickness="6"
                        UseAeroCaptionButtons="False" />
  </shell:WindowChrome.WindowChrome>
  <Window.Resources>
    <SolidColorBrush x:Key="PanelBrush" Color="#21252B" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#31363F" />
    <SolidColorBrush x:Key="AccentBrush" Color="#5AA9E6" />
    <SolidColorBrush x:Key="MutedBrush" Color="#B7BDC6" />
    <SolidColorBrush x:Key="OverlayBrush" Color="#CC11161C" />
    <SolidColorBrush x:Key="PaneChromeBrush" Color="#171C22" />
    <SolidColorBrush x:Key="PaneChromeBorderBrush" Color="#28313B" />
    <SolidColorBrush x:Key="PaneSelectedBrush" Color="#1D2934" />
    <SolidColorBrush x:Key="PaneSelectedBorderBrush" Color="#5AA9E6" />
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#FFFFFF" />
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#111111" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#E5E7EB" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#111111" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FFFFFF" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#111111" />
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FFFFFF" />
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#111111" />

    <DrawingImage x:Key="PlayIcon">
      <DrawingImage.Drawing>
        <GeometryDrawing Brush="#F3F4F6" Geometry="M 4,3 L 18,10 L 4,17 Z" />
      </DrawingImage.Drawing>
    </DrawingImage>

    <DrawingImage x:Key="TitleBarAppIcon">
      <DrawingImage.Drawing>
        <DrawingGroup>
          <GeometryDrawing Brush="{x:Null}">
            <GeometryDrawing.Pen>
              <Pen Brush="#1F2937"
                   Thickness="1.6"
                   StartLineCap="Round"
                   EndLineCap="Round"
                   LineJoin="Round" />
            </GeometryDrawing.Pen>
            <GeometryDrawing.Geometry>
              <RectangleGeometry Rect="2.5,2.5,15,15" RadiusX="2" RadiusY="2" />
            </GeometryDrawing.Geometry>
          </GeometryDrawing>
          <GeometryDrawing Brush="#2563EB"
                           Geometry="M 7,6.5 L 13.5,10 L 7,13.5 Z" />
        </DrawingGroup>
      </DrawingImage.Drawing>
    </DrawingImage>

    <DrawingImage x:Key="PauseIcon">
      <DrawingImage.Drawing>
        <DrawingGroup>
          <GeometryDrawing Brush="#F3F4F6" Geometry="M 4,3 H 9 V 17 H 4 Z" />
          <GeometryDrawing Brush="#F3F4F6" Geometry="M 13,3 H 18 V 17 H 13 Z" />
        </DrawingGroup>
      </DrawingImage.Drawing>
    </DrawingImage>

    <DrawingImage x:Key="RewindIcon">
      <DrawingImage.Drawing>
        <DrawingGroup>
          <GeometryDrawing Brush="#F3F4F6" Geometry="M 10,3 L 2,10 L 10,17 Z" />
          <GeometryDrawing Brush="#F3F4F6" Geometry="M 19,3 L 11,10 L 19,17 Z" />
        </DrawingGroup>
      </DrawingImage.Drawing>
    </DrawingImage>

    <DrawingImage x:Key="FastForwardIcon">
      <DrawingImage.Drawing>
        <DrawingGroup>
          <GeometryDrawing Brush="#F3F4F6" Geometry="M 3,3 L 11,10 L 3,17 Z" />
          <GeometryDrawing Brush="#F3F4F6" Geometry="M 12,3 L 20,10 L 12,17 Z" />
        </DrawingGroup>
      </DrawingImage.Drawing>
    </DrawingImage>

    <DrawingImage x:Key="StepBackIcon">
      <DrawingImage.Drawing>
        <DrawingGroup>
          <GeometryDrawing Brush="#F3F4F6" Geometry="M 3,3 H 5 V 17 H 3 Z" />
          <GeometryDrawing Brush="#F3F4F6" Geometry="M 18,3 L 7,10 L 18,17 Z" />
        </DrawingGroup>
      </DrawingImage.Drawing>
    </DrawingImage>

    <DrawingImage x:Key="StepForwardIcon">
      <DrawingImage.Drawing>
        <DrawingGroup>
          <GeometryDrawing Brush="#F3F4F6" Geometry="M 19,3 H 21 V 17 H 19 Z" />
          <GeometryDrawing Brush="#F3F4F6" Geometry="M 6,3 L 17,10 L 6,17 Z" />
        </DrawingGroup>
      </DrawingImage.Drawing>
    </DrawingImage>

    <DrawingImage x:Key="FullScreenIcon">
      <DrawingImage.Drawing>
        <GeometryDrawing Brush="{x:Null}">
          <GeometryDrawing.Pen>
            <Pen Brush="#F3F4F6" Thickness="2" StartLineCap="Square" EndLineCap="Square" LineJoin="Miter" />
          </GeometryDrawing.Pen>
          <GeometryDrawing.Geometry>
            <GeometryGroup>
              <LineGeometry StartPoint="3,8" EndPoint="3,3" />
              <LineGeometry StartPoint="3,3" EndPoint="8,3" />
              <LineGeometry StartPoint="16,3" EndPoint="21,3" />
              <LineGeometry StartPoint="21,3" EndPoint="21,8" />
              <LineGeometry StartPoint="21,16" EndPoint="21,21" />
              <LineGeometry StartPoint="21,21" EndPoint="16,21" />
              <LineGeometry StartPoint="8,21" EndPoint="3,21" />
              <LineGeometry StartPoint="3,21" EndPoint="3,16" />
            </GeometryGroup>
          </GeometryDrawing.Geometry>
        </GeometryDrawing>
      </DrawingImage.Drawing>
    </DrawingImage>

    <DrawingImage x:Key="ExitFullScreenIcon">
      <DrawingImage.Drawing>
        <GeometryDrawing Brush="{x:Null}">
          <GeometryDrawing.Pen>
            <Pen Brush="#F3F4F6" Thickness="2" StartLineCap="Square" EndLineCap="Square" LineJoin="Miter" />
          </GeometryDrawing.Pen>
          <GeometryDrawing.Geometry>
            <GeometryGroup>
              <LineGeometry StartPoint="8,3" EndPoint="8,8" />
              <LineGeometry StartPoint="8,8" EndPoint="3,8" />
              <LineGeometry StartPoint="16,3" EndPoint="16,8" />
              <LineGeometry StartPoint="16,8" EndPoint="21,8" />
              <LineGeometry StartPoint="21,16" EndPoint="16,16" />
              <LineGeometry StartPoint="16,16" EndPoint="16,21" />
              <LineGeometry StartPoint="8,21" EndPoint="8,16" />
              <LineGeometry StartPoint="8,16" EndPoint="3,16" />
            </GeometryGroup>
          </GeometryDrawing.Geometry>
        </GeometryDrawing>
      </DrawingImage.Drawing>
    </DrawingImage>

    <Style TargetType="Button">
      <Setter Property="Margin" Value="0,0,6,0" />
      <Setter Property="Padding" Value="11,7" />
      <Setter Property="Background" Value="#2A2F37" />
      <Setter Property="Foreground" Value="#F3F4F6" />
      <Setter Property="BorderBrush" Value="#3B424D" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#343B45" />
                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#1F242A" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="Menu">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#111111" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Menu">
            <Border Background="{TemplateBinding Background}">
              <StackPanel Orientation="Horizontal"
                          IsItemsHost="True"
                          KeyboardNavigation.TabNavigation="Cycle" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="MenuItem">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#111111" />
      <Setter Property="Padding" Value="8,4" />
      <Style.Triggers>
        <Trigger Property="IsHighlighted" Value="True">
          <Setter Property="Background" Value="#E5E7EB" />
          <Setter Property="Foreground" Value="#111111" />
        </Trigger>
        <Trigger Property="IsSubmenuOpen" Value="True">
          <Setter Property="Background" Value="#E5E7EB" />
          <Setter Property="Foreground" Value="#111111" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="TitleBarMenuSeparatorStyle" TargetType="Separator">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Separator">
            <Border Height="1"
                    Margin="10,4"
                    Background="#E5E7EB" />
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="TitleBarSubmenuItemStyle" TargetType="MenuItem">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#111111" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="MenuItem">
            <Grid SnapsToDevicePixels="True">
              <Border x:Name="SubmenuBorder"
                      Background="{TemplateBinding Background}">
                <Grid MinWidth="220">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <ContentPresenter Grid.Column="0"
                                    Margin="14,7,18,7"
                                    VerticalAlignment="Center"
                                    ContentSource="Header"
                                    RecognizesAccessKey="True" />
                  <TextBlock x:Name="GestureTextBlock"
                             Grid.Column="1"
                             Margin="0,7,14,7"
                             VerticalAlignment="Center"
                             Foreground="#4B5563"
                             Text="{TemplateBinding InputGestureText}" />
                  <TextBlock x:Name="StateGlyphTextBlock"
                             Grid.Column="2"
                             Margin="0,7,12,7"
                             VerticalAlignment="Center"
                             Foreground="#111111"
                             FontSize="14"
                             Text=""
                             Visibility="Collapsed" />
                </Grid>
              </Border>
              <Popup x:Name="PART_Popup"
                     AllowsTransparency="True"
                     Focusable="False"
                     HorizontalOffset="-1"
                     IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                     Placement="Right"
                     PopupAnimation="None">
                <Border Background="#FFFFFF"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1">
                  <StackPanel IsItemsHost="True"
                              KeyboardNavigation.DirectionalNavigation="Cycle" />
                </Border>
              </Popup>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="Role" Value="SubmenuHeader">
                <Setter TargetName="StateGlyphTextBlock" Property="Text" Value="›" />
                <Setter TargetName="StateGlyphTextBlock" Property="Visibility" Value="Visible" />
              </Trigger>
              <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="SubmenuBorder" Property="Background" Value="#F9FAFB" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="#9CA3AF" />
                <Setter TargetName="GestureTextBlock" Property="Foreground" Value="#9CA3AF" />
                <Setter TargetName="StateGlyphTextBlock" Property="Foreground" Value="#9CA3AF" />
              </Trigger>
              <MultiTrigger>
                <MultiTrigger.Conditions>
                  <Condition Property="IsCheckable" Value="True" />
                  <Condition Property="IsChecked" Value="True" />
                </MultiTrigger.Conditions>
                <Setter TargetName="StateGlyphTextBlock" Property="Text" Value="✓" />
                <Setter TargetName="StateGlyphTextBlock" Property="Visibility" Value="Visible" />
              </MultiTrigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="TitleBarTopLevelMenuItemStyle" TargetType="MenuItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#111111" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="Margin" Value="0,0,2,0" />
      <Setter Property="ItemContainerStyle" Value="{StaticResource TitleBarSubmenuItemStyle}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="MenuItem">
            <Grid SnapsToDevicePixels="True">
              <Border x:Name="TopLevelBorder"
                      Background="{TemplateBinding Background}">
                <ContentPresenter Margin="{TemplateBinding Padding}"
                                  VerticalAlignment="Center"
                                  ContentSource="Header"
                                  RecognizesAccessKey="True" />
              </Border>
              <Popup x:Name="PART_Popup"
                     AllowsTransparency="True"
                     Focusable="False"
                     HorizontalOffset="0"
                     IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                     Placement="Bottom"
                     PopupAnimation="None"
                     VerticalOffset="1">
                <Border Background="#FFFFFF"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1">
                  <StackPanel IsItemsHost="True"
                              KeyboardNavigation.DirectionalNavigation="Cycle" />
                </Border>
              </Popup>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="TopLevelBorder" Property="Background" Value="#F9FAFB" />
              </Trigger>
              <Trigger Property="IsSubmenuOpen" Value="True">
                <Setter TargetName="TopLevelBorder" Property="Background" Value="#F9FAFB" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="#9CA3AF" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="EmptyStateActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="MinWidth" Value="160" />
      <Setter Property="Padding" Value="22,12" />
      <Setter Property="FontSize" Value="14" />
    </Style>

    <Style x:Key="TransportButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Width" Value="36" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontSize" Value="15" />
    </Style>

    <Style x:Key="PaneControlButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Height" Value="28" />
      <Setter Property="MinWidth" Value="42" />
      <Setter Property="Padding" Value="10,4" />
      <Setter Property="Margin" Value="0,0,6,0" />
      <Setter Property="FontSize" Value="11" />
    </Style>

    <Style x:Key="PaneChromeBorderStyle" TargetType="Border">
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="{StaticResource PaneChromeBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource PaneChromeBorderBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style x:Key="PaneFooterBorderStyle" TargetType="Border" BasedOn="{StaticResource PaneChromeBorderStyle}">
      <Setter Property="BorderThickness" Value="0,1,0,0" />
    </Style>

    <Style x:Key="TitleBarButtonStyle" TargetType="Button">
      <Setter Property="Width" Value="46" />
      <Setter Property="Height" Value="34" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#111111" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#F3F4F6" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#E5E7EB" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="TitleBarCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#E81123" />
          <Setter Property="Foreground" Value="#FFFFFF" />
        </Trigger>
        <Trigger Property="IsPressed" Value="True">
          <Setter Property="Background" Value="#C50F1F" />
          <Setter Property="Foreground" Value="#FFFFFF" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="Background" Value="#1C2026" />
      <Setter Property="Foreground" Value="#F3F4F6" />
      <Setter Property="BorderBrush" Value="#3B424D" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="CheckBox">
      <Setter Property="Foreground" Value="#F3F4F6" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Margin" Value="0,0,0,4" />
    </Style>
  </Window.Resources>

  <Border x:Name="WindowFrameBorder"
          Background="#17191D"
          BorderBrush="#2B3138"
          BorderThickness="1"
          CornerRadius="0"
          ClipToBounds="False">
    <Grid x:Name="RootGrid">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

    <Border x:Name="MenuPanel"
            Grid.Row="0"
            Background="#FFFFFF"
            BorderBrush="#D1D5DB"
            BorderThickness="0,0,0,1">
      <Grid Height="38">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="10,0,6,0"
                Background="Transparent"
                MouseLeftButtonDown="TitleBarDragRegion_MouseLeftButtonDown">
          <Image Width="16"
                 Height="16"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Center"
                 Source="{StaticResource TitleBarAppIcon}" />
        </Border>

        <Menu Grid.Column="1"
              VerticalAlignment="Center"
              Background="Transparent">
          <MenuItem Style="{StaticResource TitleBarTopLevelMenuItemStyle}" Header="_File">
            <MenuItem Header="_Open Video..."
                      InputGestureText="Ctrl+O"
                      Click="OpenFileButton_Click" />
            <MenuItem x:Name="RecentFilesMenuItem" Header="Open _Recent" />
            <MenuItem x:Name="CloseVideoMenuItem"
                      Header="_Close Video"
                      InputGestureText="Ctrl+W"
                      Click="CloseVideoMenuItem_Click" />
            <MenuItem x:Name="VideoInfoMenuItem"
                      Header="Video _Info..."
                      Click="VideoInfoMenuItem_Click" />
            <MenuItem Header="Export _Diagnostics..."
                      InputGestureText="Ctrl+Shift+E"
                      Click="ExportDiagnosticsMenuItem_Click" />
            <Separator Style="{StaticResource TitleBarMenuSeparatorStyle}" />
            <MenuItem Header="E_xit" Click="ExitMenuItem_Click" />
          </MenuItem>
          <MenuItem Style="{StaticResource TitleBarTopLevelMenuItemStyle}" Header="_Playback">
            <MenuItem x:Name="PlayPauseMenuItem" Header="_Play" InputGestureText="Space" Click="PlayPauseButton_Click" />
            <Separator Style="{StaticResource TitleBarMenuSeparatorStyle}" />
            <MenuItem Header="_Rewind 5s" InputGestureText="," Click="RewindButton_Click" />
            <MenuItem Header="_Fast Forward 5s" InputGestureText="." Click="FastForwardButton_Click" />
            <Separator Style="{StaticResource TitleBarMenuSeparatorStyle}" />
            <MenuItem Header="Previous _Frame" InputGestureText="Left" Click="PreviousFrameButton_Click" />
            <MenuItem Header="_Next Frame" InputGestureText="Right" Click="NextFrameButton_Click" />
            <MenuItem x:Name="LoopPlaybackMenuItem"
                      Header="_Loop Playback"
                      InputGestureText="L"
                      IsCheckable="True"
                      Checked="LoopPlaybackMenuItem_Checked"
                      Unchecked="LoopPlaybackMenuItem_Unchecked" />
            <MenuItem x:Name="SetLoopInMenuItem"
                      Header="Set Loop _In"
                      InputGestureText="["
                      Click="SetLoopInMenuItem_Click" />
            <MenuItem x:Name="SetLoopOutMenuItem"
                      Header="Set Loop _Out"
                      InputGestureText="]"
                      Click="SetLoopOutMenuItem_Click" />
            <MenuItem x:Name="ClearLoopPointsMenuItem"
                      Header="_Clear Loop Points"
                      Click="ClearLoopPointsMenuItem_Click" />
            <MenuItem x:Name="SaveLoopAsClipMenuItem"
                      Header="_Save Loop As Clip..."
                      Click="SaveLoopAsClipMenuItem_Click" />
            <Separator Style="{StaticResource TitleBarMenuSeparatorStyle}" />
            <MenuItem x:Name="UseGpuAccelerationMenuItem"
                      Header="Use _GPU Acceleration"
                      IsCheckable="True"
                      Checked="UseGpuAccelerationMenuItem_Checked"
                      Unchecked="UseGpuAccelerationMenuItem_Unchecked" />
            <Separator Style="{StaticResource TitleBarMenuSeparatorStyle}" />
            <MenuItem Header="_Toggle Full Screen" InputGestureText="F11" Click="ToggleFullScreenMenuItem_Click" />
          </MenuItem>
          <MenuItem Style="{StaticResource TitleBarTopLevelMenuItemStyle}" Header="_Help">
            <MenuItem Header="_Controls and Shortcuts"
                      InputGestureText="F1"
                      Click="HelpMenuItem_Click" />
            <Separator Style="{StaticResource TitleBarMenuSeparatorStyle}" />
            <MenuItem Header="_About Frame Player"
                      Click="AboutMenuItem_Click" />
          </MenuItem>
        </Menu>

        <Border Grid.Column="2"
                Background="Transparent"
                MouseLeftButtonDown="TitleBarDragRegion_MouseLeftButtonDown" />

        <StackPanel Grid.Column="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
          <Button Style="{StaticResource TitleBarButtonStyle}"
                  Click="MinimizeWindowButton_Click">
            <TextBlock FontFamily="Segoe MDL2 Assets"
                       FontSize="10"
                       Text="&#xE921;" />
          </Button>
          <Button x:Name="WindowStateButton"
                  Style="{StaticResource TitleBarButtonStyle}"
                  Click="WindowStateButton_Click">
            <TextBlock x:Name="WindowStateGlyphTextBlock"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="10"
                       Text="&#xE922;" />
          </Button>
          <Button Style="{StaticResource TitleBarCloseButtonStyle}"
                  Click="CloseWindowButton_Click">
            <TextBlock FontFamily="Segoe MDL2 Assets"
                       FontSize="10"
                       Text="&#xE8BB;" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <Border x:Name="HeaderPanel"
            Grid.Row="1"
            Margin="10,10,10,0"
            Padding="10"
            Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="10">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel>
            <TextBlock Text="Current Video"
                       Foreground="{StaticResource MutedBrush}"
                       FontSize="11" />
            <TextBlock x:Name="CurrentFileTextBlock"
                       Margin="0,3,0,0"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Text="No file loaded"
                       TextTrimming="CharacterEllipsis" />
          </StackPanel>
          <CheckBox x:Name="CompareModeCheckBox"
                    Grid.Column="1"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    Content="Two-Pane Compare"
                    Checked="CompareModeCheckBox_Checked"
                    Unchecked="CompareModeCheckBox_Unchecked" />
        </Grid>

        <Border x:Name="CompareToolbarBorder"
                Grid.Row="1"
                Margin="0,10,0,0"
                Padding="8,6"
                Background="{StaticResource PaneChromeBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="0"
                Visibility="Collapsed">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <CheckBox x:Name="AllPanesCheckBox"
                      Content="Control both panes"
