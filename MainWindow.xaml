<Window x:Class="FramePlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Frame Player"
        Width="1280"
        Height="820"
        MinWidth="1040"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="#17191D"
        Foreground="#F3F4F6"
        FontFamily="Segoe UI"
        AllowDrop="True"
        Closed="Window_Closed"
        Drop="Window_Drop"
        PreviewDragOver="Window_PreviewDragOver"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp">
  <Window.Resources>
    <SolidColorBrush x:Key="PanelBrush" Color="#21252B" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#31363F" />
    <SolidColorBrush x:Key="AccentBrush" Color="#5AA9E6" />
    <SolidColorBrush x:Key="MutedBrush" Color="#B7BDC6" />
    <SolidColorBrush x:Key="OverlayBrush" Color="#CC11161C" />
    <SolidColorBrush x:Key="PaneChromeBrush" Color="#171C22" />
    <SolidColorBrush x:Key="PaneChromeBorderBrush" Color="#28313B" />
    <SolidColorBrush x:Key="PaneSelectedBrush" Color="#1D2934" />
    <SolidColorBrush x:Key="PaneSelectedBorderBrush" Color="#5AA9E6" />
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#21252B" />
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#F3F4F6" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#343B45" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#F3F4F6" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#21252B" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#F3F4F6" />
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#21252B" />
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#F3F4F6" />

    <DrawingImage x:Key="PlayIcon">
      <DrawingImage.Drawing>
        <GeometryDrawing Brush="#F3F4F6" Geometry="M 4,3 L 18,10 L 4,17 Z" />
      </DrawingImage.Drawing>
    </DrawingImage>

    <DrawingImage x:Key="PauseIcon">
      <DrawingImage.Drawing>
        <DrawingGroup>
          <GeometryDrawing Brush="#F3F4F6" Geometry="M 4,3 H 9 V 17 H 4 Z" />
          <GeometryDrawing Brush="#F3F4F6" Geometry="M 13,3 H 18 V 17 H 13 Z" />
        </DrawingGroup>
      </DrawingImage.Drawing>
    </DrawingImage>

    <DrawingImage x:Key="RewindIcon">
      <DrawingImage.Drawing>
        <DrawingGroup>
          <GeometryDrawing Brush="#F3F4F6" Geometry="M 10,3 L 2,10 L 10,17 Z" />
          <GeometryDrawing Brush="#F3F4F6" Geometry="M 19,3 L 11,10 L 19,17 Z" />
        </DrawingGroup>
      </DrawingImage.Drawing>
    </DrawingImage>

    <DrawingImage x:Key="FastForwardIcon">
      <DrawingImage.Drawing>
        <DrawingGroup>
          <GeometryDrawing Brush="#F3F4F6" Geometry="M 3,3 L 11,10 L 3,17 Z" />
          <GeometryDrawing Brush="#F3F4F6" Geometry="M 12,3 L 20,10 L 12,17 Z" />
        </DrawingGroup>
      </DrawingImage.Drawing>
    </DrawingImage>

    <DrawingImage x:Key="StepBackIcon">
      <DrawingImage.Drawing>
        <DrawingGroup>
          <GeometryDrawing Brush="#F3F4F6" Geometry="M 3,3 H 5 V 17 H 3 Z" />
          <GeometryDrawing Brush="#F3F4F6" Geometry="M 18,3 L 7,10 L 18,17 Z" />
        </DrawingGroup>
      </DrawingImage.Drawing>
    </DrawingImage>

    <DrawingImage x:Key="StepForwardIcon">
      <DrawingImage.Drawing>
        <DrawingGroup>
          <GeometryDrawing Brush="#F3F4F6" Geometry="M 19,3 H 21 V 17 H 19 Z" />
          <GeometryDrawing Brush="#F3F4F6" Geometry="M 6,3 L 17,10 L 6,17 Z" />
        </DrawingGroup>
      </DrawingImage.Drawing>
    </DrawingImage>

    <DrawingImage x:Key="FullScreenIcon">
      <DrawingImage.Drawing>
        <GeometryDrawing Brush="{x:Null}">
          <GeometryDrawing.Pen>
            <Pen Brush="#F3F4F6" Thickness="2" StartLineCap="Square" EndLineCap="Square" LineJoin="Miter" />
          </GeometryDrawing.Pen>
          <GeometryDrawing.Geometry>
            <GeometryGroup>
              <LineGeometry StartPoint="3,8" EndPoint="3,3" />
              <LineGeometry StartPoint="3,3" EndPoint="8,3" />
              <LineGeometry StartPoint="16,3" EndPoint="21,3" />
              <LineGeometry StartPoint="21,3" EndPoint="21,8" />
              <LineGeometry StartPoint="21,16" EndPoint="21,21" />
              <LineGeometry StartPoint="21,21" EndPoint="16,21" />
              <LineGeometry StartPoint="8,21" EndPoint="3,21" />
              <LineGeometry StartPoint="3,21" EndPoint="3,16" />
            </GeometryGroup>
          </GeometryDrawing.Geometry>
        </GeometryDrawing>
      </DrawingImage.Drawing>
    </DrawingImage>

    <DrawingImage x:Key="ExitFullScreenIcon">
      <DrawingImage.Drawing>
        <GeometryDrawing Brush="{x:Null}">
          <GeometryDrawing.Pen>
            <Pen Brush="#F3F4F6" Thickness="2" StartLineCap="Square" EndLineCap="Square" LineJoin="Miter" />
          </GeometryDrawing.Pen>
          <GeometryDrawing.Geometry>
            <GeometryGroup>
              <LineGeometry StartPoint="8,3" EndPoint="8,8" />
              <LineGeometry StartPoint="8,8" EndPoint="3,8" />
              <LineGeometry StartPoint="16,3" EndPoint="16,8" />
              <LineGeometry StartPoint="16,8" EndPoint="21,8" />
              <LineGeometry StartPoint="21,16" EndPoint="16,16" />
              <LineGeometry StartPoint="16,16" EndPoint="16,21" />
              <LineGeometry StartPoint="8,21" EndPoint="8,16" />
              <LineGeometry StartPoint="8,16" EndPoint="3,16" />
            </GeometryGroup>
          </GeometryDrawing.Geometry>
        </GeometryDrawing>
      </DrawingImage.Drawing>
    </DrawingImage>

    <Style TargetType="Button">
      <Setter Property="Margin" Value="0,0,6,0" />
      <Setter Property="Padding" Value="11,7" />
      <Setter Property="Background" Value="#2A2F37" />
      <Setter Property="Foreground" Value="#F3F4F6" />
      <Setter Property="BorderBrush" Value="#3B424D" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#343B45" />
                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#1F242A" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="Menu">
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="Foreground" Value="#F3F4F6" />
    </Style>

    <Style TargetType="MenuItem">
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="Foreground" Value="#F3F4F6" />
      <Setter Property="Padding" Value="8,4" />
      <Style.Triggers>
        <Trigger Property="IsHighlighted" Value="True">
          <Setter Property="Background" Value="#343B45" />
          <Setter Property="Foreground" Value="#FFFFFF" />
        </Trigger>
        <Trigger Property="IsSubmenuOpen" Value="True">
          <Setter Property="Background" Value="#343B45" />
          <Setter Property="Foreground" Value="#FFFFFF" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="TransportButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Width" Value="36" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontSize" Value="15" />
    </Style>

    <Style x:Key="PaneControlButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Height" Value="28" />
      <Setter Property="MinWidth" Value="42" />
      <Setter Property="Padding" Value="10,4" />
      <Setter Property="Margin" Value="0,0,6,0" />
      <Setter Property="FontSize" Value="11" />
    </Style>

    <Style x:Key="PaneChromeBorderStyle" TargetType="Border">
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="{StaticResource PaneChromeBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource PaneChromeBorderBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style x:Key="PaneFooterBorderStyle" TargetType="Border" BasedOn="{StaticResource PaneChromeBorderStyle}">
      <Setter Property="BorderThickness" Value="1,1,0,0" />
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="Background" Value="#1C2026" />
      <Setter Property="Foreground" Value="#F3F4F6" />
      <Setter Property="BorderBrush" Value="#3B424D" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="CheckBox">
      <Setter Property="Foreground" Value="#F3F4F6" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Margin" Value="0,0,0,4" />
    </Style>
  </Window.Resources>

  <Grid x:Name="RootGrid" Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border x:Name="MenuPanel"
            Grid.Row="0"
            Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
      <Menu BorderThickness="0">
        <MenuItem Header="_File">
          <MenuItem Header="_Open Video..."
                    InputGestureText="Ctrl+O"
                    Click="OpenFileButton_Click" />
          <MenuItem x:Name="RecentFilesMenuItem" Header="Open _Recent" />
          <MenuItem x:Name="CloseVideoMenuItem"
                    Header="_Close Video"
                    InputGestureText="Ctrl+W"
                    Click="CloseVideoMenuItem_Click" />
          <MenuItem Header="Export _Diagnostics..."
                    InputGestureText="Ctrl+Shift+E"
                    Click="ExportDiagnosticsMenuItem_Click" />
          <Separator />
          <MenuItem Header="E_xit" Click="ExitMenuItem_Click" />
        </MenuItem>
        <MenuItem Header="_Playback">
          <MenuItem x:Name="PlayPauseMenuItem" Header="_Play" InputGestureText="Space" Click="PlayPauseButton_Click" />
          <Separator />
          <MenuItem Header="_Rewind 5s" InputGestureText="J" Click="RewindButton_Click" />
          <MenuItem Header="_Fast Forward 5s" InputGestureText="L" Click="FastForwardButton_Click" />
          <Separator />
          <MenuItem Header="Previous _Frame" InputGestureText="Left" Click="PreviousFrameButton_Click" />
          <MenuItem Header="_Next Frame" InputGestureText="Right" Click="NextFrameButton_Click" />
          <Separator />
          <MenuItem Header="_Toggle Full Screen" InputGestureText="F11" Click="ToggleFullScreenMenuItem_Click" />
        </MenuItem>
        <MenuItem Header="_Help">
          <MenuItem Header="_Controls and Shortcuts"
                    InputGestureText="F1"
                    Click="HelpMenuItem_Click" />
          <Separator />
          <MenuItem Header="_About Frame Player"
                    Click="AboutMenuItem_Click" />
        </MenuItem>
      </Menu>
    </Border>

    <Border x:Name="HeaderPanel"
            Grid.Row="1"
            Margin="0,8,0,0"
            Padding="10"
            Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="10">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel>
            <TextBlock Text="Current Video"
                       Foreground="{StaticResource MutedBrush}"
                       FontSize="11" />
            <TextBlock x:Name="CurrentFileTextBlock"
                       Margin="0,3,0,0"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Text="No file loaded"
                       TextTrimming="CharacterEllipsis" />
          </StackPanel>
          <CheckBox x:Name="CompareModeCheckBox"
                    Grid.Column="1"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    Content="Two-Pane Compare"
                    Checked="CompareModeCheckBox_Checked"
                    Unchecked="CompareModeCheckBox_Unchecked" />
        </Grid>

        <Border x:Name="CompareToolbarBorder"
                Grid.Row="1"
                Margin="0,10,0,0"
                Padding="8,6"
                Background="{StaticResource PaneChromeBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="Collapsed">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <CheckBox x:Name="AllPanesCheckBox"
                      Content="Control both panes"
                      Margin="0,0,10,0"
                      Checked="AllPanesCheckBox_Checked"
                      Unchecked="AllPanesCheckBox_Unchecked" />
            <Button x:Name="AlignRightToLeftButton"
                    Grid.Column="1"
                    Style="{StaticResource PaneControlButtonStyle}"
                    Content="Align Right to Left"
                    ToolTip="Frame first: uses the left pane's exact frame when available and falls back to time only when needed."
                    Click="AlignRightToLeftButton_Click" />
            <Button x:Name="AlignLeftToRightButton"
                    Grid.Column="2"
                    Style="{StaticResource PaneControlButtonStyle}"
                    Margin="0,0,0,0"
                    Content="Align Left to Right"
                    ToolTip="Frame first: uses the right pane's exact frame when available and falls back to time only when needed."
                    Click="AlignLeftToRightButton_Click" />
            <TextBlock x:Name="CompareStatusTextBlock"
                       Grid.Column="3"
                       Margin="12,0,0,0"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource MutedBrush}"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis"
                       Text="Compare: Load two videos | Last align: none" />
          </Grid>
        </Border>
      </Grid>
    </Border>

    <Border x:Name="VideoPanel"
            Grid.Row="2"
            Margin="0,8,0,0"
            Background="#101317"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition x:Name="PrimaryPaneColumn" Width="*" />
          <ColumnDefinition x:Name="ComparePaneColumn" Width="0" />
        </Grid.ColumnDefinitions>

        <Border x:Name="PrimaryPaneBorder"
                Grid.Column="0"
                Background="#101317"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Tag="pane-primary"
                MouseLeftButtonDown="VideoPane_MouseLeftButtonDown">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="PrimaryPaneHeaderBorder"
                    Grid.Row="0"
                    Style="{StaticResource PaneChromeBorderStyle}"
                    Visibility="Collapsed">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                  <TextBlock x:Name="PrimaryPaneTitleTextBlock"
                             FontSize="13"
                             FontWeight="SemiBold"
                             Text="Primary" />
                  <TextBlock x:Name="PrimaryPaneFileTextBlock"
                             Margin="0,2,0,0"
                             Foreground="{StaticResource MutedBrush}"
                             FontSize="11"
                             TextTrimming="CharacterEllipsis"
                             Text="No file loaded" />
                </StackPanel>
                <TextBlock x:Name="PrimaryPaneStateTextBlock"
                           Grid.Column="1"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="11"
                           TextAlignment="Right"
                           Text="Ready" />
              </Grid>
            </Border>

            <Grid Grid.Row="1">
              <Border x:Name="CustomVideoSurfaceHost"
                      Background="#101317"
                      Focusable="True">
                <Image x:Name="CustomVideoSurface"
                       Stretch="Uniform"
                       SnapsToDevicePixels="True"
                       RenderOptions.BitmapScalingMode="NearestNeighbor" />
              </Border>

              <Border x:Name="PrimaryEmptyStateOverlay"
                      Margin="18"
                      Padding="18"
                      MaxWidth="380"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Background="{StaticResource OverlayBrush}"
                      BorderBrush="#554A5564"
                      BorderThickness="1"
                      CornerRadius="14">
                <StackPanel>
                  <TextBlock x:Name="PrimaryEmptyStateTitleTextBlock"
                             FontSize="20"
                             FontWeight="SemiBold"
                             TextAlignment="Center"
                             Text="Drop a video here" />
                  <TextBlock x:Name="PrimaryEmptyStateBodyTextBlock"
                             Margin="0,10,0,0"
                             Foreground="{StaticResource MutedBrush}"
                             FontSize="13"
                             TextAlignment="Center"
                             TextWrapping="Wrap"
                             Text="Or open a video to begin" />
                  <Button Margin="0,14,0,0"
                          Padding="14,8"
                          HorizontalAlignment="Center"
                          Tag="pane-primary"
                          Content="Open Video"
                          Click="OpenPaneButton_Click" />
                </StackPanel>
              </Border>
            </Grid>

            <Border x:Name="PrimaryPaneFooterBorder"
                    Grid.Row="2"
                    Style="{StaticResource PaneFooterBorderStyle}"
                    Visibility="Collapsed">
              <StackPanel x:Name="PrimaryPaneControlsPanel"
                          HorizontalAlignment="Center"
                          Orientation="Horizontal"
                          Visibility="Collapsed">
                <Button x:Name="PrimaryPaneStepBackButton"
                        Style="{StaticResource PaneControlButtonStyle}"
                        Content="Back"
                        Tag="pane-primary"
                        Click="PaneStepBackButton_Click" />
                <Button x:Name="PrimaryPanePlayButton"
                        Style="{StaticResource PaneControlButtonStyle}"
                        Content="Play"
                        Tag="pane-primary"
                        Click="PanePlayButton_Click" />
                <Button x:Name="PrimaryPanePauseButton"
                        Style="{StaticResource PaneControlButtonStyle}"
                        Content="Pause"
                        Tag="pane-primary"
                        Click="PanePauseButton_Click" />
                <Button x:Name="PrimaryPaneStepForwardButton"
                        Style="{StaticResource PaneControlButtonStyle}"
                        Margin="0,0,0,0"
                        Content="Next"
                        Tag="pane-primary"
                        Click="PaneStepForwardButton_Click" />
              </StackPanel>
            </Border>
          </Grid>
        </Border>

        <Border x:Name="ComparePaneBorder"
                Grid.Column="1"
                Margin="8,0,0,0"
                Background="#101317"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Tag="pane-compare-a"
                Visibility="Collapsed"
                MouseLeftButtonDown="VideoPane_MouseLeftButtonDown">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="ComparePaneHeaderBorder"
                    Grid.Row="0"
                    Style="{StaticResource PaneChromeBorderStyle}"
                    Visibility="Collapsed">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                  <TextBlock x:Name="ComparePaneTitleTextBlock"
                             FontSize="13"
                             FontWeight="SemiBold"
                             Text="Compare" />
                  <TextBlock x:Name="ComparePaneFileTextBlock"
                             Margin="0,2,0,0"
                             Foreground="{StaticResource MutedBrush}"
                             FontSize="11"
                             TextTrimming="CharacterEllipsis"
                             Text="No file loaded" />
                </StackPanel>
                <TextBlock x:Name="ComparePaneStateTextBlock"
                           Grid.Column="1"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="11"
                           TextAlignment="Right"
                           Text="Empty" />
              </Grid>
            </Border>

            <Grid Grid.Row="1">
              <Border x:Name="CompareVideoSurfaceHost"
                      Background="#101317"
                      Focusable="True">
                <Image x:Name="CompareVideoSurface"
                       Stretch="Uniform"
                       SnapsToDevicePixels="True"
                       RenderOptions.BitmapScalingMode="NearestNeighbor" />
              </Border>

              <Border x:Name="CompareEmptyStateOverlay"
                      Margin="18"
                      Padding="18"
                      MaxWidth="380"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Background="{StaticResource OverlayBrush}"
                      BorderBrush="#554A5564"
                      BorderThickness="1"
                      CornerRadius="14">
                <StackPanel>
                  <TextBlock x:Name="CompareEmptyStateTitleTextBlock"
                             FontSize="20"
                             FontWeight="SemiBold"
                             TextAlignment="Center"
                             Text="Add a compare video" />
                  <TextBlock x:Name="CompareEmptyStateBodyTextBlock"
                             Margin="0,10,0,0"
                             Foreground="{StaticResource MutedBrush}"
                             FontSize="13"
                             TextAlignment="Center"
                             TextWrapping="Wrap"
                             Text="Load a second video to compare against the left pane" />
                  <Button Margin="0,14,0,0"
                          Padding="14,8"
                          HorizontalAlignment="Center"
                          Tag="pane-compare-a"
                          Content="Open Compare Video"
                          Click="OpenPaneButton_Click" />
                </StackPanel>
              </Border>
            </Grid>

            <Border x:Name="ComparePaneFooterBorder"
                    Grid.Row="2"
                    Style="{StaticResource PaneFooterBorderStyle}"
                    Visibility="Collapsed">
              <StackPanel x:Name="ComparePaneControlsPanel"
                          HorizontalAlignment="Center"
                          Orientation="Horizontal"
                          Visibility="Collapsed">
                <Button x:Name="ComparePaneStepBackButton"
                        Style="{StaticResource PaneControlButtonStyle}"
                        Content="Back"
                        Tag="pane-compare-a"
                        Click="PaneStepBackButton_Click" />
                <Button x:Name="ComparePanePlayButton"
                        Style="{StaticResource PaneControlButtonStyle}"
                        Content="Play"
                        Tag="pane-compare-a"
                        Click="PanePlayButton_Click" />
                <Button x:Name="ComparePanePauseButton"
                        Style="{StaticResource PaneControlButtonStyle}"
                        Content="Pause"
                        Tag="pane-compare-a"
                        Click="PanePauseButton_Click" />
                <Button x:Name="ComparePaneStepForwardButton"
                        Style="{StaticResource PaneControlButtonStyle}"
                        Margin="0,0,0,0"
                        Content="Next"
                        Tag="pane-compare-a"
                        Click="PaneStepForwardButton_Click" />
              </StackPanel>
            </Border>
          </Grid>
        </Border>

        <Border x:Name="FullscreenControlBar"
                Grid.ColumnSpan="2"
                Visibility="Collapsed"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Margin="0,0,0,14"
                Padding="10"
                Background="{StaticResource OverlayBrush}"
                BorderBrush="#554A5564"
                BorderThickness="1"
                CornerRadius="12">
          <StackPanel Orientation="Horizontal">
            <Button Style="{StaticResource TransportButtonStyle}"
                    ToolTip="Previous Frame"
                    Click="PreviousFrameButton_Click">
              <Image Width="16" Height="16" Source="{StaticResource StepBackIcon}" />
            </Button>
            <Button Style="{StaticResource TransportButtonStyle}"
                    ToolTip="Rewind 5 Seconds"
                    Click="RewindButton_Click">
              <Image Width="16" Height="16" Source="{StaticResource RewindIcon}" />
            </Button>
            <Button Style="{StaticResource TransportButtonStyle}"
                    x:Name="OverlayPlayPauseButton"
                    ToolTip="Play"
                    Click="PlayPauseButton_Click">
              <Image x:Name="OverlayPlayPauseIcon" Width="16" Height="16" Source="{StaticResource PlayIcon}" />
            </Button>
            <Button Style="{StaticResource TransportButtonStyle}"
                    ToolTip="Fast Forward 5 Seconds"
                    Click="FastForwardButton_Click">
              <Image Width="16" Height="16" Source="{StaticResource FastForwardIcon}" />
            </Button>
            <Button Style="{StaticResource TransportButtonStyle}"
                    ToolTip="Next Frame"
                    Click="NextFrameButton_Click">
              <Image Width="16" Height="16" Source="{StaticResource StepForwardIcon}" />
            </Button>
            <Button x:Name="OverlayToggleFullScreenButton"
                    Style="{StaticResource TransportButtonStyle}"
                    Margin="10,0,0,0"
                    ToolTip="Exit Full Screen"
                    Click="ToggleFullScreenButton_Click">
              <Image x:Name="OverlayToggleFullScreenIcon"
                     Width="16"
                     Height="16"
                     Source="{StaticResource ExitFullScreenIcon}" />
            </Button>
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <Border x:Name="ControlPanel"
            Grid.Row="3"
            Margin="0,8,0,0"
            Padding="10"
            Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="10">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <TextBlock x:Name="CurrentPositionTextBlock"
                     VerticalAlignment="Center"
                     FontSize="13"
                     Width="96"
                     TextAlignment="Left"
                     Text="00:00:00.000" />

          <Slider x:Name="PositionSlider"
                  Grid.Column="1"
                  Margin="8,0"
                  Minimum="0"
                  Maximum="1"
                  IsMoveToPointEnabled="False"
                  ValueChanged="PositionSlider_ValueChanged" />

          <TextBlock x:Name="DurationTextBlock"
                     Grid.Column="2"
                     VerticalAlignment="Center"
                     FontSize="13"
                     Width="96"
                     TextAlignment="Right"
                     Text="00:00:00.000" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,8,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Orientation="Horizontal" Grid.Column="0">
            <Button x:Name="PreviousFrameButton"
                    Style="{StaticResource TransportButtonStyle}"
                    ToolTip="Previous Frame"
                    Click="PreviousFrameButton_Click">
              <Image Width="16" Height="16" Source="{StaticResource StepBackIcon}" />
            </Button>
            <Button x:Name="RewindButton"
                    Style="{StaticResource TransportButtonStyle}"
                    ToolTip="Rewind 5 Seconds"
                    Click="RewindButton_Click">
              <Image Width="16" Height="16" Source="{StaticResource RewindIcon}" />
            </Button>
            <Button x:Name="PlayPauseButton"
                    Style="{StaticResource TransportButtonStyle}"
                    ToolTip="Play"
                    Click="PlayPauseButton_Click">
              <Image x:Name="PlayPauseIcon" Width="16" Height="16" Source="{StaticResource PlayIcon}" />
            </Button>
            <Button x:Name="FastForwardButton"
                    Style="{StaticResource TransportButtonStyle}"
                    ToolTip="Fast Forward 5 Seconds"
                    Click="FastForwardButton_Click">
              <Image Width="16" Height="16" Source="{StaticResource FastForwardIcon}" />
            </Button>
            <Button x:Name="NextFrameButton"
                    Style="{StaticResource TransportButtonStyle}"
                    ToolTip="Next Frame"
                    Click="NextFrameButton_Click">
              <Image Width="16" Height="16" Source="{StaticResource StepForwardIcon}" />
            </Button>
            <Button x:Name="ToggleFullScreenButton"
                    Style="{StaticResource TransportButtonStyle}"
                    Margin="10,0,0,0"
                    ToolTip="Toggle Full Screen"
                    Click="ToggleFullScreenButton_Click">
              <Image x:Name="ToggleFullScreenIcon"
                     Width="16"
                     Height="16"
                     Source="{StaticResource FullScreenIcon}" />
            </Button>
          </StackPanel>

          <DockPanel Grid.Column="2" LastChildFill="False">
            <TextBlock VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Foreground="{StaticResource MutedBrush}"
                       FontSize="12"
                       Text="Frame" />
            <TextBox x:Name="FrameNumberTextBox"
                     Width="76"
                     HorizontalContentAlignment="Right"
                     GotKeyboardFocus="FrameNumberTextBox_GotKeyboardFocus"
                     KeyDown="FrameNumberTextBox_KeyDown" />
          </DockPanel>
        </Grid>
      </Grid>
    </Border>

    <StatusBar x:Name="StatusPanel"
               Grid.Row="4"
               Margin="0,8,0,0"
               Padding="4,3"
               Background="{StaticResource PanelBrush}"
               BorderBrush="{StaticResource PanelBorderBrush}"
               BorderThickness="1"
               Foreground="#F3F4F6">
      <StatusBarItem>
        <TextBlock x:Name="PlaybackStateTextBlock"
                   FontSize="12"
                   Width="360"
                   TextTrimming="CharacterEllipsis"
                   Text="A/V playback + frame review" />
      </StatusBarItem>
      <Separator />
      <StatusBarItem>
        <StackPanel Orientation="Horizontal">
          <TextBlock x:Name="CurrentFrameTextBlock"
                     Foreground="{StaticResource MutedBrush}"
                     FontSize="12"
                     Width="140"
                     TextTrimming="CharacterEllipsis"
                     Text="Frame --" />
          <TextBlock Margin="8,0"
                     Foreground="{StaticResource MutedBrush}"
                     FontSize="12"
                     Text="|" />
          <TextBlock x:Name="TimecodeTextBlock"
                     Foreground="{StaticResource MutedBrush}"
                     FontSize="12"
                     Width="240"
                     TextTrimming="CharacterEllipsis"
                     Text="--:--:--.--- / --:--:--.---" />
        </StackPanel>
      </StatusBarItem>
      <Separator />
      <StatusBarItem>
        <TextBlock x:Name="CacheStatusTextBlock"
                   Foreground="{StaticResource MutedBrush}"
                   FontSize="12"
                   Width="250"
                   TextTrimming="CharacterEllipsis"
                   Text="Cache: idle" />
      </StatusBarItem>
      <StatusBarItem Visibility="Collapsed">
        <TextBlock x:Name="MediaSummaryTextBlock"
                   Text="" />
      </StatusBarItem>
    </StatusBar>
  </Grid>
</Window>
