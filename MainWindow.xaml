                         Foreground="{StaticResource MutedBrush}"
                         FontSize="12"
                         Text="|" />
              <TextBlock x:Name="TimecodeTextBlock"
                         Foreground="{StaticResource MutedBrush}"
                         FontSize="12"
                         Width="240"
                         TextTrimming="CharacterEllipsis"
                         Text="--:--:--.--- / --:--:--.---" />
            </StackPanel>
          </StatusBarItem>
          <Separator />
          <StatusBarItem>
            <TextBlock x:Name="CacheStatusTextBlock"
                       Foreground="{StaticResource MutedBrush}"
                       FontSize="12"
                       Width="220"
                       TextTrimming="CharacterEllipsis"
                       Text="Cache: idle" />
          </StatusBarItem>
          <Separator />
          <StatusBarItem>
            <TextBlock x:Name="PointerCoordinatesTextBlock"
                       Foreground="{StaticResource MutedBrush}"
                       FontSize="12"
                       Width="230"
                       TextTrimming="CharacterEllipsis"
                       Text="Pixel: --" />
          </StatusBarItem>
          <StatusBarItem Visibility="Collapsed">
            <TextBlock x:Name="MediaSummaryTextBlock"
                       Text="" />
          </StatusBarItem>
        </StatusBar>
      </Border>
    </Grid>
  </Border>
</Window>
